{
  "manifest_version": 3,
  "name": "AnkLeet",
  "version": "1.0.0",
  "description": "Automatically track every LeetCode submission",
  "permissions": ["storage", "alarms", "notifications"],
  "host_permissions": ["https://leetcode.com/*", "https://neetcode.io/*", "https://openrouter.ai/*", "https://fonts.googleapis.com/*", "https://fonts.gstatic.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/problems/*"],
      "js": ["content-main.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://leetcode.com/problems/*"],
      "js": ["content-isolated.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://leetcode.com/problems/*"],
      "js": ["content-toast.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["https://leetcode.com/problems/*"],
      "js": ["content-chat.js"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
